---
// 404 — Not Found (MEAT-18). Serving 404.html as the actual 404 response is a
// host-config concern (MEAT-33). noindex so it never lands in search results.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The page you’re looking for doesn’t exist." noindex>
  <h1>404 — Page not found</h1>
  <p>Sorry, we couldn’t find that page.</p>
  <p><a href="/">Back to home</a></p>
</BaseLayout>
