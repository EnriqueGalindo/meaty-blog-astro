---
// Single post — /posts/<slug>/ (MEAT-18, image pipeline reworked by MEAT-41).
//
// Routes on the collection entry `id` (== slug; MEAT-17). Single-segment param
// fails loud if a slug ever contains a slash, surfacing bad data rather than
// silently 404ing (plan v2, fix #5). Drafts are excluded in prod via the same
// getPublishedPosts() predicate as the home list, so no orphan draft page is
// ever built (plan v2, fix #1).
import { Image, getImage } from 'astro:assets';
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, date, description, heroImage, heroImageAlt, seoTitle, ogImage } =
  entry.data;

// Body renders through <Content /> (MEAT-41): local Markdown images (`![](./x)`)
// are only run through the sharp pipeline by the content component, not in the
// raw `rendered.html` string. The leading-body-<h1> demotion that used to live
// here as a regex now happens at the migration source (MEAT-12), so the page
// still keeps exactly ONE <h1> (the frontmatter title below).
const { Content } = await render(entry);

// OG card: emit a fixed 1200x630 variant. getImage() both materializes the
// asset into the build (a meta-only image is otherwise never emitted) and gives
// us its hashed src, which we make absolute against `site` for crawlers.
const og = await getImage({
  src: ogImage ?? heroImage,
  width: 1200,
  height: 630,
});
const ogImageUrl = new URL(og.src, Astro.site).toString();

const fmt = new Intl.DateTimeFormat('en-US', {
  dateStyle: 'long',
  timeZone: 'UTC',
});
---

<BaseLayout
  title={seoTitle ?? title}
  description={description}
  ogTitle={title}
  ogImage={ogImageUrl}
  ogImageAlt={heroImageAlt}
  ogType="article"
>
  <article>
    <Image src={heroImage} alt={heroImageAlt} loading="eager" />
    {/* The page's single H1 comes from frontmatter; body h1s are demoted at source. */}
    <h1>{title}</h1>
    <time datetime={date.toISOString().slice(0, 10)}>{fmt.format(date)}</time>
    <Content />
  </article>
</BaseLayout>
