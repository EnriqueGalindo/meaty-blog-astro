---
// Home — intro + "Today's Menu" chalkboard menu board + the full post list.
//
// Mockup-faithful per D1 (MEAT-45 / D9): the chalkboard is a real menu of posts
// (featured "Today's Cut" + "This Week's Catch List"), not a wordmark hero. The
// site wordmark moves to the shared header (MEAT-44); the icon below is a
// decorative bridge until then. Designed cards = D4; "THE FULL CASE" restyle,
// author/footer (D6), and personalized/data-eng copy (MEAT-43) are out of scope.
import BaseLayout from '../layouts/BaseLayout.astro';
import TodaysMenu from '../components/TodaysMenu.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts } from '../lib/posts';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = await getPublishedPosts();
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  {/* INTRO — paper. Carries the page's single <h1>. The brand wordmark/stamp
      lives in the site header (MEAT-44). */}
  <section class="intro container">
    <h1 class="intro__title">Getting into the meat of it.</h1>
  </section>

  {/* TODAY'S MENU — the chalkboard menu board (MEAT-45 / D9). */}
  {
    posts.length > 0 && (
      <div class="container board-wrap">
        <TodaysMenu posts={posts} />
      </div>
    )
  }

  {/* FULL POST LIST — "The Full Case" archive (D4.1 / MEAT-46): dark strip +
      ticket rows + CTA. Labelled region so it shows in the landmark map. */}
  <section class="menu container" aria-labelledby="menu-heading">
    <div class="arch-head">
      <h2 id="menu-heading" class="arch-head__title">
        <span aria-hidden="true">🥩</span> The Full Case
      </h2>
      <span class="arch-head__note" aria-hidden="true">everything in the shop</span>
    </div>

    {
      posts.length === 0 ? (
        <p class="menu__empty">No posts yet.</p>
      ) : (
        <>
          <ul class="card-list" role="list">
            {posts.map((post) => (
              <li>
                <PostCard post={post} />
              </li>
            ))}
          </ul>
          {/* Placeholder until an archive / pagination exists (the home already
              lists every post); non-interactive so it isn't a dead link. */}
          <div class="more">
            <span class="btn" aria-hidden="true">Browse the whole case &rarr;</span>
          </div>
        </>
      )
    }
  </section>
</BaseLayout>

<style>
  /* --- Intro -------------------------------------------------------------- */
  .intro {
    padding-block: var(--space-8) var(--space-6);
    text-align: center;
  }
  .intro__title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: var(--fw-bold);
    font-size: clamp(2rem, 6vw, var(--fs-h1));
    line-height: var(--lh-tight);
    color: var(--color-text);
  }

  .board-wrap {
    padding-bottom: var(--space-4);
  }

  /* --- Post list ---------------------------------------------------------- */
  .menu {
    padding-block: var(--space-8);
  }
  /* "The Full Case" archive strip. */
  .arch-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-2);
    padding: var(--space-3) var(--space-5);
    background: var(--color-inverse-bg);
    color: var(--color-inverse-text);
    border-radius: var(--radius-md);
  }
  .arch-head__title {
    margin: 0;
    font-family: var(--font-sign);
    font-weight: var(--fw-bold);
    font-size: var(--fs-lead);
    letter-spacing: var(--tracking-sign);
    text-transform: uppercase;
  }
  .arch-head__note {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--tracking-wide);
    color: var(--color-highlight);
  }
  .card-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  /* CTA button — D1 ink block-shadow (placeholder; see markup note). */
  .more {
    margin-top: var(--space-7);
    text-align: center;
  }
  .btn {
    display: inline-block;
    font-family: var(--font-sign);
    font-weight: var(--fw-bold);
    font-size: var(--fs-small);
    letter-spacing: var(--tracking-sign);
    text-transform: uppercase;
    color: var(--color-on-accent);
    background: var(--color-accent);
    padding: var(--space-3) var(--space-6);
    border: var(--border-rule) solid var(--color-text);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-block-ink);
  }
  .menu__empty {
    color: var(--color-text-muted);
  }

  @media (max-width: 30rem) {
    .arch-head__note {
      display: none;
    }
  }
</style>
