---
// Home — intro + "Today's Menu" chalkboard menu board + the full post list.
//
// Mockup-faithful per D1 (MEAT-45 / D9): the chalkboard is a real menu of posts
// (featured "Today's Cut" + "This Week's Catch List"), not a wordmark hero. The
// site wordmark moves to the shared header (MEAT-44); the icon below is a
// decorative bridge until then. Designed cards = D4; "THE FULL CASE" restyle,
// author/footer (D6), and personalized/data-eng copy (MEAT-43) are out of scope.
import BaseLayout from '../layouts/BaseLayout.astro';
import TodaysMenu from '../components/TodaysMenu.astro';
import PostCard from '../components/PostCard.astro';
import { getPublishedPosts } from '../lib/posts';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = await getPublishedPosts();
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  {/* INTRO — paper. Carries the page's single <h1>. The brand mark is decorative
      (the "MEATY BLOG" wordmark lives in the header, MEAT-44). */}
  <section class="intro container">
    <img
      class="intro__mark"
      src="/brand/logo-icon.svg"
      alt=""
      aria-hidden="true"
      width="72"
      height="72"
    />
    <h1 class="intro__title">Getting into the meat of it.</h1>
  </section>

  {/* TODAY'S MENU — the chalkboard menu board (MEAT-45 / D9). */}
  {
    posts.length > 0 && (
      <div class="container board-wrap">
        <TodaysMenu posts={posts} />
      </div>
    )
  }

  {/* FULL POST LIST — designed cards (D4). The "THE FULL CASE" strip + CTA is a
      separate revise-D4 card. Labelled region so it shows in the landmark map. */}
  <section class="menu container" aria-labelledby="menu-heading">
    <h2 id="menu-heading" class="menu__heading">Fresh Cuts</h2>

    {
      posts.length === 0 ? (
        <p class="menu__empty">No posts yet.</p>
      ) : (
        <ul class="card-list" role="list">
          {posts.map((post) => (
            <li>
              <PostCard post={post} />
            </li>
          ))}
        </ul>
      )
    }
  </section>
</BaseLayout>

<style>
  /* --- Intro -------------------------------------------------------------- */
  .intro {
    padding-block: var(--space-8) var(--space-6);
    text-align: center;
  }
  .intro__mark {
    display: block;
    width: 72px;
    height: auto;
    margin: 0 auto var(--space-4);
  }
  .intro__title {
    margin: 0;
    font-family: var(--font-serif);
    font-weight: var(--fw-bold);
    font-size: clamp(2rem, 6vw, var(--fs-h1));
    line-height: var(--lh-tight);
    color: var(--color-text);
  }

  .board-wrap {
    padding-bottom: var(--space-4);
  }

  /* --- Post list ---------------------------------------------------------- */
  .menu {
    padding-block: var(--space-8);
  }
  .menu__heading {
    margin: 0 0 var(--space-6);
    font-family: var(--font-sign);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-h2);
    letter-spacing: var(--tracking-sign);
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .card-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-6);
  }
  .menu__empty {
    color: var(--color-text-muted);
  }
</style>
