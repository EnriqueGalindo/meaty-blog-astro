---
// Home — lists published posts, newest first (MEAT-18).
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../lib/posts';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = await getPublishedPosts();

// Human-readable date label, formatted in UTC so it matches the machine-readable
// `datetime` attribute and never rolls back a day across timezones
// (MEAT-18 plan v2, fix #6).
const fmt = new Intl.DateTimeFormat('en-US', {
  dateStyle: 'long',
  timeZone: 'UTC',
});
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <h1>{SITE_TITLE}</h1>
  {
    posts.length === 0 ? (
      <p>No posts yet.</p>
    ) : (
      <ul>
        {posts.map((post) => (
          <li>
            <article>
              <h2>
                <a href={`/posts/${post.id}/`}>{post.data.title}</a>
              </h2>
              <time datetime={post.data.date.toISOString().slice(0, 10)}>
                {fmt.format(post.data.date)}
              </time>
              <p>{post.data.description}</p>
            </article>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
