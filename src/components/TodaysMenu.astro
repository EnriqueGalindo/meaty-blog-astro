---
// TodaysMenu — the "Today's Menu" chalkboard menu board (MEAT-45 / D9).
//
// Restores the D1 brand mockup's framed menu board: a featured "Today's Cut"
// (newest post) + a "This Week's Catch List" of the next 3, with read-time
// "prices". Posts arrive newest-first (getPublishedPosts). Categories and
// data-eng copy are deferred to MEAT-43 ("layout now, content later").
import type { PostEntry } from '../lib/posts';
import { readingTimeMinutes } from '../lib/reading-time';

interface Props {
  posts: PostEntry[];
  headingId?: string;
}

const { posts, headingId = 'todays-menu-heading' } = Astro.props;

const featured = posts[0];
const catchList = posts.slice(1, 4);

// Decorative "today's menu" date — build time, in UTC; refreshes per deploy.
const boardDate = new Intl.DateTimeFormat('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
  timeZone: 'UTC',
}).format(new Date());
---

<section class="board" data-surface="dark" aria-labelledby={headingId}>
  <div class="board__inner">
    <h2 id={headingId} class="board__title">Today&rsquo;s Menu</h2>
    <p class="board__date" aria-hidden="true">{boardDate}</p>
    <hr class="board__rule" aria-hidden="true" />

    {
      featured && (
        <div class="board__cut">
          <p class="board__eyebrow" aria-hidden="true">Today&rsquo;s Cut</p>
          <h3 class="board__cut-title">
            <a href={`/posts/${featured.id}/`}>{featured.data.title}</a>
          </h3>
          <p class="board__cut-dek">{featured.data.description}</p>
          <p class="board__tag">{readingTimeMinutes(featured.body)} MIN READ</p>
        </div>
      )
    }

    {
      catchList.length > 0 && (
        <div class="board__catch">
          <h3 class="board__catch-title">This Week&rsquo;s Catch List</h3>
          <p class="board__catch-sub" aria-hidden="true">Fresh cuts, butchered daily</p>
          <ul class="board__list" role="list">
            {catchList.map((post) => (
              <li class="board__row">
                <a class="board__row-link" href={`/posts/${post.id}/`}>
                  {post.data.title}
                </a>
                <span class="board__leader" aria-hidden="true" />
                <span class="board__row-time">{readingTimeMinutes(post.body)} min</span>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <p class="board__foot" aria-hidden="true">&mdash; ask about the daily special &mdash;</p>
  </div>
</section>

<style>
  /* Wood-framed slate board — centered card, not full-bleed (matches the mockup). */
  .board {
    max-width: 640px;
    margin-inline: auto;
    background: var(--color-board-frame);
    padding: var(--space-2);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lift);
  }
  .board__inner {
    padding: var(--space-7) var(--space-6) var(--space-6);
    border-radius: var(--radius-sm);
    /* faint chalk inner edge, derived from the board text token */
    border: var(--border-hairline) solid
      color-mix(in srgb, var(--color-board-text) 14%, transparent);
    background: var(--color-board-bg);
    color: var(--color-board-text);
    text-align: center;
  }

  /* --- Board header ------------------------------------------------------- */
  .board__title {
    margin: 0;
    font-family: var(--font-chalk);
    font-weight: var(--fw-bold);
    /* fluid so the script title never overflows narrow viewports */
    font-size: clamp(2.5rem, 9vw, var(--fs-display));
    line-height: var(--lh-tight);
    color: var(--color-board-text);
  }
  .board__date {
    margin: var(--space-2) 0 0;
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-board-accent);
  }
  .board__rule {
    margin: var(--space-5) 0;
    border: 0;
    border-top: var(--border-hairline) dashed
      color-mix(in srgb, var(--color-board-text) 35%, transparent);
  }

  /* --- Today's Cut (featured) --------------------------------------------- */
  .board__cut {
    margin-bottom: var(--space-6);
  }
  .board__eyebrow {
    margin: 0 0 var(--space-1);
    font-family: var(--font-chalk);
    font-size: var(--fs-h3);
    color: var(--color-board-accent);
  }
  .board__cut-title {
    margin: 0 0 var(--space-3);
    font-family: var(--font-sign);
    font-weight: var(--fw-bold);
    font-size: var(--fs-h2);
    line-height: var(--lh-snug);
    letter-spacing: var(--tracking-sign);
    text-transform: uppercase;
    overflow-wrap: break-word;
  }
  .board__cut-title a {
    color: var(--color-board-text);
    text-decoration: none;
  }
  .board__cut-title a:hover,
  .board__cut-title a:focus-visible {
    text-decoration: underline;
  }
  .board__cut-dek {
    margin: 0 auto var(--space-4);
    max-width: 46ch;
    font-family: var(--font-serif);
    line-height: var(--lh-normal);
    color: var(--color-board-text-muted);
  }
  .board__tag {
    display: inline-block;
    margin: 0;
    padding: var(--space-2) var(--space-3);
    border: var(--border-hairline) solid
      color-mix(in srgb, var(--color-board-text) 40%, transparent);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--tracking-wide);
    color: var(--color-board-text);
  }

  /* --- This Week's Catch List --------------------------------------------- */
  .board__catch-title {
    margin: 0;
    font-family: var(--font-chalk);
    font-size: clamp(2rem, 7vw, var(--fs-h1));
    line-height: var(--lh-tight);
    color: var(--color-board-text);
  }
  .board__catch-sub {
    margin: var(--space-1) 0 var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-board-text-muted);
  }
  .board__list {
    list-style: none;
    margin: 0;
    padding: 0;
    text-align: left;
  }
  .board__row {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-3) 0;
  }
  .board__row + .board__row {
    border-top: var(--border-hairline) solid
      color-mix(in srgb, var(--color-board-text) 14%, transparent);
  }
  .board__row-link {
    flex: 0 1 auto;
    font-family: var(--font-sign);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-lead);
    letter-spacing: var(--tracking-sign);
    text-transform: uppercase;
    color: var(--color-board-text);
    text-decoration: none;
    overflow-wrap: break-word;
  }
  .board__row-link:hover,
  .board__row-link:focus-visible {
    text-decoration: underline;
  }
  /* dotted "menu leader" filling the space between title and price */
  .board__leader {
    flex: 1 1 auto;
    align-self: flex-end;
    margin-bottom: 0.3em;
    min-width: var(--space-5);
    border-bottom: var(--border-hairline) dotted
      color-mix(in srgb, var(--color-board-text) 45%, transparent);
  }
  .board__row-time {
    flex: 0 0 auto;
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--tracking-wide);
    color: var(--color-board-text-muted);
    white-space: nowrap;
  }

  /* --- Footer flourish ---------------------------------------------------- */
  .board__foot {
    margin: var(--space-6) 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--fs-body);
    color: var(--color-board-text-muted);
  }

  @media (max-width: 30rem) {
    .board__inner {
      padding: var(--space-6) var(--space-4) var(--space-5);
    }
  }
</style>
