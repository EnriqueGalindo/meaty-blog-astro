---
// PostCard — one row in "The Full Case" archive list (MEAT-24, restyled by
// MEAT-46 / D4.1 to the D1 mockup).
//
// Flat dashed-divider row: a rotated read-time "ticket" (no hero image — the
// ticket replaces the thumbnail per the mockup) + body (date, title link, dek).
// Stretched-link pattern: the <article> is positioned and the title link's
// ::after overlays the row, so each row exposes exactly ONE link (the title)
// while the whole row is clickable. Read-time reuses the MEAT-45 util.
import type { PostEntry } from '../lib/posts';
import { readingTimeMinutes } from '../lib/reading-time';

interface Props {
  post: PostEntry;
}

const { post } = Astro.props;
const { title, date, description } = post.data;
const mins = readingTimeMinutes(post.body);

// UTC so the label matches the machine-readable datetime and never rolls a day
// across timezones (MEAT-18).
const fmt = new Intl.DateTimeFormat('en-US', { dateStyle: 'long', timeZone: 'UTC' });
---

<article class="card">
  <div class="card__ticket">
    <span class="card__mins">{mins}<span class="card__mins-u">min</span></span>
    <span class="card__est">est. read</span>
    <span class="card__barcode" aria-hidden="true"></span>
  </div>

  <div class="card__body">
    <p class="card__meta">
      <time datetime={date.toISOString().slice(0, 10)}>{fmt.format(date)}</time>
    </p>
    <h3 class="card__title">
      <a href={`/posts/${post.id}/`}>{title}</a>
    </h3>
    <p class="card__desc">{description}</p>
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    gap: var(--space-5);
    align-items: flex-start;
    padding-block: var(--space-5);
    border-bottom: var(--border-hairline) dashed var(--color-border);
  }
  /* Keyboard focus ring on the whole row (the stretched link is the only
     focusable child); the link's own outline is suppressed so it isn't doubled. */
  .card:has(a:focus-visible) {
    outline: var(--border-rule) solid var(--color-focus);
    outline-offset: 4px;
  }

  /* Read-time "ticket" — replaces the hero thumbnail. */
  .card__ticket {
    flex: 0 0 92px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-2);
    background: var(--color-surface);
    border: var(--border-rule) solid var(--color-text);
    border-radius: var(--radius-sm);
    transform: rotate(-1.5deg);
  }
  .card__mins {
    font-family: var(--font-sign);
    font-weight: var(--fw-bold);
    font-size: var(--fs-h2);
    line-height: 1;
    color: var(--color-accent);
  }
  .card__mins-u {
    margin-left: 2px;
    font-size: var(--fs-meta);
  }
  .card__est {
    margin-top: var(--space-1);
    font-family: var(--font-mono);
    font-size: 0.5rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .card__barcode {
    width: 100%;
    height: 16px;
    margin-top: var(--space-1);
    background: repeating-linear-gradient(
      90deg,
      var(--color-text) 0 2px,
      transparent 2px 4px,
      var(--color-text) 4px 5px,
      transparent 5px 8px
    );
  }

  .card__body {
    flex: 1 1 auto;
    min-width: 0;
  }
  .card__meta {
    margin: 0 0 var(--space-1);
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .card__title {
    margin: 0 0 var(--space-2);
    font-family: var(--font-serif);
    font-weight: var(--fw-bold);
    font-size: var(--fs-h3);
    line-height: var(--lh-snug);
    overflow-wrap: break-word;
  }
  .card__title a {
    color: var(--color-text);
    text-decoration: none;
  }
  .card__title a:hover,
  .card__title a:focus-visible {
    text-decoration: underline;
  }
  .card__title a:focus-visible {
    outline: none;
  }
  /* Stretched link: overlay the whole row so it's all clickable while the title
     stays the single link in the a11y tree. */
  .card__title a::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .card__desc {
    margin: 0;
    color: var(--color-text-muted);
    /* Clamp to keep rows even; full text lives on the post page. */
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }

  @media (max-width: 30rem) {
    .card {
      gap: var(--space-4);
    }
    .card__ticket {
      flex-basis: 74px;
    }
    .card__mins {
      font-size: var(--fs-h3);
    }
  }
</style>
