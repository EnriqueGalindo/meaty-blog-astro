---
// Site header — shared chrome / banner (MEAT-44 / D8).
//
// Matches the D1 homepage mockup: awning strip → bar with the "USDA PRIME /
// Inspected" grade-stamp + "MEATY BLOG" wordmark (+ "EST. 2026 · DATA CO."
// sub-line) as the home link, and a POSTS / ABOUT / SUBSCRIBE nav. The whole
// lockup is the home <a> (never a heading — post pages keep their single <h1>);
// its accessible name resolves once via aria-label, with the badge aria-hidden.
//
// About/Subscribe have no pages yet, so they render as non-interactive
// placeholders (no dead links) until those cards land.
const path = Astro.url.pathname;
const isHome = path === '/' || path === '';
---

<header class="site-header">
  <div class="site-header__awning" aria-hidden="true"></div>
  <div class="site-header__bar">
    <a class="site-header__brand" href="/" aria-label="Meaty Blog — home">
      <span class="site-header__badge" aria-hidden="true">
        <span class="site-header__badge-top">USDA</span>
        <span class="site-header__badge-big">PRIME</span>
        <span class="site-header__badge-bot">Inspected</span>
      </span>
      <span class="site-header__name">
        Meaty Blog
        <small class="site-header__est">EST. 2026 &middot; DATA CO.</small>
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <a href="/" aria-current={isHome ? 'page' : undefined}>Posts</a>
      <span class="site-header__soon" title="Coming soon">About</span>
      <span class="site-header__soon" title="Coming soon">Subscribe</span>
    </nav>
  </div>
</header>

<style>
  /* Deli-awning stripe along the very top edge of the page. */
  .site-header__awning {
    height: 14px;
    background: var(--awning-stripe);
    border-bottom: var(--border-heavy) solid var(--color-text);
  }

  .site-header {
    background: var(--color-surface);
    border-bottom: var(--border-heavy) solid var(--color-text);
  }
  .site-header__bar {
    max-width: var(--container);
    margin-inline: auto;
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* --- Brand lockup (home link) ------------------------------------------ */
  .site-header__brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text);
    text-decoration: none;
  }

  /* "USDA PRIME / Inspected" grade-stamp badge. */
  .site-header__badge {
    flex: 0 0 auto;
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: var(--radius-round);
    border: var(--border-rule) solid var(--color-accent);
    color: var(--color-accent);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    line-height: 1;
    font-family: var(--font-sign);
    transform: rotate(-7deg);
  }
  .site-header__badge::before {
    content: '';
    position: absolute;
    inset: 5px;
    border-radius: var(--radius-round);
    border: var(--border-hairline) dashed var(--color-accent);
    opacity: 0.7;
  }
  .site-header__badge-top {
    font-weight: var(--fw-bold);
    font-size: 0.5rem;
    letter-spacing: 0.15em;
  }
  .site-header__badge-big {
    font-weight: var(--fw-bold);
    font-size: 1.125rem;
  }
  .site-header__badge-bot {
    font-weight: var(--fw-semibold);
    font-size: 0.4375rem;
    letter-spacing: 0.08em;
  }

  .site-header__name {
    font-family: var(--font-sign);
    font-weight: var(--fw-bold);
    font-size: var(--fs-h2);
    line-height: 0.9;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .site-header__est {
    display: block;
    margin-top: var(--space-1);
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    font-weight: var(--fw-regular);
    letter-spacing: var(--tracking-wide);
    text-transform: none;
    color: var(--color-text-muted);
  }

  /* --- Nav ---------------------------------------------------------------- */
  .site-header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }
  .site-header__nav a,
  .site-header__soon {
    font-family: var(--font-sign);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-small);
    letter-spacing: var(--tracking-sign);
    text-transform: uppercase;
    color: var(--color-text);
  }
  .site-header__nav a {
    text-decoration: none;
  }
  .site-header__nav a:hover,
  .site-header__nav a:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
  }
  .site-header__nav a[aria-current='page'] {
    color: var(--color-accent);
    text-decoration: underline;
  }
  /* Placeholder items — present but not yet linked (no pages exist). */
  .site-header__soon {
    cursor: default;
  }

  @media (max-width: 30rem) {
    .site-header__bar {
      padding: var(--space-3) var(--space-4);
      gap: var(--space-2) var(--space-4);
    }
    .site-header__badge {
      width: 52px;
      height: 52px;
    }
    .site-header__badge-big {
      font-size: 0.9375rem;
    }
    .site-header__name {
      font-size: var(--fs-h3);
    }
    .site-header__nav {
      width: 100%;
      justify-content: flex-start;
      gap: var(--space-4);
    }
  }
</style>
