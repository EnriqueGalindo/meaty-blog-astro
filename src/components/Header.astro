---
// Site header — shared chrome / banner (MEAT-44 / D8).
//
// Mockup lockup layout, but with OUR brand mark: awning strip → bar with the
// official round inspection stamp (logo-stamp.svg, tilted like the mockup badge)
// + "MEATY BLOG" wordmark (+ "EST. 2026 · DATA CO." sub-line) as the home link,
// and a POSTS / ABOUT / SUBSCRIBE nav. The whole lockup is the home <a> (never a
// heading — post pages keep their single <h1>); its accessible name resolves
// once via aria-label, with the stamp aria-hidden. The stamp is inlined so its
// live Oswald <textPath> renders with the loaded webfont.
//
// About/Subscribe have no pages yet, so they render as non-interactive
// placeholders (no dead links) until those cards land.
import { site } from '../config/site';

const path = Astro.url.pathname;
const isHome = path === '/' || path === '';
---

<header class="site-header">
  <div class="site-header__awning" aria-hidden="true"></div>
  <div class="site-header__bar">
    <a class="site-header__brand" href="/" aria-label={`${site.title} — home`}>
      <svg class="site-header__stamp" viewBox="0 0 140 140" aria-hidden="true" focusable="false">
        <defs>
          <path id="hdr-arc-top" d="M22,70 A48,48 0 0 1 118,70" fill="none"></path>
          <path id="hdr-arc-bot" d="M26,70 A44,44 0 0 0 114,70" fill="none"></path>
        </defs>
        <circle cx="70" cy="70" r="60" fill="none" stroke="#9e2b25" stroke-width="3"></circle>
        <circle cx="70" cy="70" r="46" fill="none" stroke="#9e2b25" stroke-width="1.4" stroke-dasharray="3 3"></circle>
        <text class="site-header__stamp-arc" font-weight="700" font-size="13" letter-spacing="2.5" fill="#9e2b25">
          <textPath href="#hdr-arc-top" startOffset="50%" text-anchor="middle">MEATY BLOG</textPath>
        </text>
        <text class="site-header__stamp-arc" font-weight="600" font-size="9" letter-spacing="2.5" fill="#9e2b25">
          <textPath href="#hdr-arc-bot" startOffset="50%" text-anchor="middle">PRIME CUTS</textPath>
        </text>
        <g transform="translate(70,72) scale(0.62) translate(-60,-60)">
          <rect x="24" y="36" width="72" height="48" fill="#9e2b25"></rect>
          <ellipse cx="60" cy="36" rx="36" ry="13" fill="#9e2b25"></ellipse>
          <ellipse cx="60" cy="84" rx="36" ry="13" fill="#9e2b25"></ellipse>
          <ellipse cx="60" cy="36" rx="36" ry="13" fill="none" stroke="#ece1d0" stroke-width="3"></ellipse>
          <path d="M26,61 q17,-7 34,0 t34,0" fill="none" stroke="#ece1d0" stroke-width="3.4"></path>
          <path d="M26,69 q17,-7 34,0 t34,0" fill="none" stroke="#ece1d0" stroke-width="3.4"></path>
        </g>
      </svg>
      <span class="site-header__name">
        {site.title}
        <small class="site-header__est">EST. {site.est} &middot; DATA CO.</small>
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      <a href="/" aria-current={isHome ? 'page' : undefined}>Posts</a>
      <span class="site-header__soon" title="Coming soon">About</span>
      <span class="site-header__soon" title="Coming soon">Subscribe</span>
    </nav>
  </div>
</header>

<style>
  /* Deli-awning stripe along the very top edge of the page. */
  .site-header__awning {
    height: 14px;
    background: var(--awning-stripe);
    border-bottom: var(--border-heavy) solid var(--color-text);
  }

  .site-header {
    background: var(--color-surface);
    border-bottom: var(--border-heavy) solid var(--color-text);
  }
  .site-header__bar {
    max-width: var(--container);
    margin-inline: auto;
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* --- Brand lockup (home link) ------------------------------------------ */
  .site-header__brand {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text);
    text-decoration: none;
  }

  /* Official round inspection stamp, tilted like the mockup badge. */
  .site-header__stamp {
    flex: 0 0 auto;
    display: block;
    width: auto;
    height: 64px;
    transform: rotate(-7deg);
  }
  /* SVG presentation attrs can't take a CSS var(); the literal in the master
     asset may not match Astro's generated @font-face name, so set the loaded
     signage font here (mirrors the D3 hero stamp). */
  .site-header__stamp-arc {
    font-family: var(--font-sign);
  }

  .site-header__name {
    font-family: var(--font-sign);
    font-weight: var(--fw-bold);
    font-size: var(--fs-h2);
    line-height: 0.9;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .site-header__est {
    display: block;
    margin-top: var(--space-1);
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    font-weight: var(--fw-regular);
    letter-spacing: var(--tracking-wide);
    text-transform: none;
    color: var(--color-text-muted);
  }

  /* --- Nav ---------------------------------------------------------------- */
  .site-header__nav {
    display: flex;
    align-items: center;
    gap: var(--space-5);
  }
  .site-header__nav a,
  .site-header__soon {
    font-family: var(--font-sign);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-small);
    letter-spacing: var(--tracking-sign);
    text-transform: uppercase;
    color: var(--color-text);
  }
  .site-header__nav a {
    text-decoration: none;
  }
  .site-header__nav a:hover,
  .site-header__nav a:focus-visible {
    color: var(--color-accent);
    text-decoration: underline;
  }
  .site-header__nav a[aria-current='page'] {
    color: var(--color-accent);
    text-decoration: underline;
  }
  /* Placeholder items — present but not yet linked (no pages exist). */
  .site-header__soon {
    cursor: default;
  }

  @media (max-width: 30rem) {
    .site-header__bar {
      padding: var(--space-3) var(--space-4);
      gap: var(--space-2) var(--space-4);
    }
    .site-header__stamp {
      height: 52px;
    }
    .site-header__name {
      font-size: var(--fs-h3);
    }
    .site-header__nav {
      width: 100%;
      justify-content: flex-start;
      gap: var(--space-4);
    }
  }
</style>
