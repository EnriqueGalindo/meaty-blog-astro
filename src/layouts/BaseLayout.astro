---
// Minimal shared layout (MEAT-18).
//
// Provides a semantic, WCAG-AA document shell and a faithful-but-minimal SEO
// head (ported from the legacy Gatsby Seo.js): title, meta description,
// canonical, Open Graph, and twitter:card. Visual design is deferred to the
// D track (MEAT-10/24/25); this file deliberately ships no design CSS.
import { SITE_TITLE } from '../consts';

interface Props {
  /** Document <title> and og:title fallback. */
  title: string;
  /** Meta description and og:description. */
  description: string;
  /** Override og:title (defaults to `title`). */
  ogTitle?: string;
  /** Absolute or site-relative OG image URL. */
  ogImage?: string;
  /** Alt text for the OG image. */
  ogImageAlt?: string;
  /** og:type — "website" (default) or "article" for posts. */
  ogType?: 'website' | 'article';
  /** Emit <meta name="robots" content="noindex"> (e.g. the 404 page). */
  noindex?: boolean;
}

const {
  title,
  description,
  ogTitle = title,
  ogImage,
  ogImageAlt,
  ogType = 'website',
  noindex = false,
} = Astro.props;

// Canonical / og:url. Astro.url already reflects the configured `site` + path.
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex" />}

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={SITE_TITLE} />
    {
      ogImage && (
        <>
          <meta property="og:image" content={ogImage} />
          {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
          {/* OG images are 1200×630 (MEAT-13). */}
          <meta property="og:image:width" content="1200" />
          <meta property="og:image:height" content="630" />
        </>
      )
    }

    {/* Twitter falls back to OG title/description, so only the card type is set. */}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />

    <style>
      /* Minimal, structural-only CSS. Visual design lives in the D track. */

      /* WCAG 2.4.1 — skip link, visible only on keyboard focus. */
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        padding: 0.5rem 1rem;
        background: #000;
        color: #fff;
      }
      .skip-link:focus {
        left: 0;
        z-index: 100;
      }

      /* Keep remote hero/OG images responsive without dictating design. */
      img {
        max-width: 100%;
        height: auto;
      }
    </style>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
  </body>
</html>
