---
// Shared layout (MEAT-18; design wired in MEAT-23/D3).
//
// Provides a semantic, WCAG-AA document shell, a faithful SEO head (title, meta
// description, canonical, Open Graph, twitter:card), the global stylesheet
// (tokens + base layer), and the self-hosted brand webfonts.
import { Font } from 'astro:assets';
import { SITE_TITLE } from '../consts';
import '../styles/global.css';

interface Props {
  /** Document <title> and og:title fallback. */
  title: string;
  /** Meta description and og:description. */
  description: string;
  /** Override og:title (defaults to `title`). */
  ogTitle?: string;
  /** Absolute or site-relative OG image URL. */
  ogImage?: string;
  /** Alt text for the OG image. */
  ogImageAlt?: string;
  /** og:type — "website" (default) or "article" for posts. */
  ogType?: 'website' | 'article';
  /** Emit <meta name="robots" content="noindex"> (e.g. the 404 page). */
  noindex?: boolean;
}

const {
  title,
  description,
  ogTitle = title,
  ogImage,
  ogImageAlt,
  ogType = 'website',
  noindex = false,
} = Astro.props;

// Canonical / og:url. Astro.url already reflects the configured `site` + path.
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

// Default OG card (MEAT-22): pages without their own image (home, 404) fall back
// to the brand default. Posts pass an absolute `ogImage`; this leaves those
// untouched. Always absolute so crawlers resolve it.
const resolvedOgImage = ogImage ?? new URL('/og-default.png', Astro.site ?? Astro.url).href;
const resolvedOgImageAlt = ogImageAlt ?? 'Meaty Blog — getting into the meat of it.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#9e2b25" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex" />}

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={SITE_TITLE} />
    {/* OG image: per-post or the brand default; always 1200×630 (MEAT-13/22). */}
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:alt" content={resolvedOgImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter falls back to OG title/description; a card image is always set. */}
    <meta name="twitter:card" content="summary_large_image" />

    {/* Self-hosted brand webfonts (MEAT-23). Preload only the above-the-fold
        faces: Oswald 700 (hero wordmark / signage), Bitter 400 (tagline/body),
        Caveat 400 (chalk accent). Mono is emitted but not preloaded. */}
    <Font cssVariable="--font-oswald" preload={[{ weight: '700' }]} />
    <Font cssVariable="--font-bitter" preload={[{ weight: '400', style: 'normal' }]} />
    <Font cssVariable="--font-caveat" preload={[{ weight: '400' }]} />
    <Font cssVariable="--font-jetbrains-mono" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
  </body>
</html>
