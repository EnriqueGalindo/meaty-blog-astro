# Copy to .env and fill in real values locally. NEVER commit a real .env.
# Contentful (read-only Content Delivery token for migration/build).
CONTENTFUL_SPACE_ID=
CONTENTFUL_ACCESS_TOKEN=

# GCS bucket holding post markdown (MEAT-17). Auth is keyless:
#   local dev -> Application Default Credentials (gcloud auth application-default login)
#   CI        -> Workload Identity Federation (no key on disk)
GCS_CONTENT_BUCKET=meatyblog-content
